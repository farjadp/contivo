// This is your Prisma schema file.
// Reference: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserPlan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum UserRole {
  USER
  ADMIN
}

enum WorkspaceStatus {
  PENDING
  CRAWLING
  ANALYZING
  READY
  ERROR
}

// Lowercase to match frontend form values and shared types
enum ContentChannel {
  linkedin
  twitter
  instagram
  email
  blog
}

enum ContentTone {
  professional
  friendly
  bold
  educational
  persuasive
}

enum ContentType {
  POST
  THREAD
  ARTICLE
  EMAIL
  CAPTION
  OUTLINE
}

enum ContentStatus {
  DRAFT
  GENERATED
  EDITED
  READY
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobType {
  INSTANT_CONTENT
  WEBSITE_CRAWL
  BRAND_ANALYSIS
  STRATEGY_GENERATION
  ARTICLE_DRAFT
}

enum LedgerType {
  ALLOCATION
  CONSUMPTION
  TOP_UP
  REFUND
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

// Social publishing enums
enum SocialPlatform {
  LINKEDIN
  X
  FACEBOOK
  INSTAGRAM
  TIKTOK
}

enum SocialConnectionStatus {
  CONNECTED
  EXPIRED
  FAILED
  REVOKED
  PENDING_REAUTH
}

enum SocialPublishStatus {
  DRAFT
  READY
  SCHEDULED
  PUBLISH_QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId      String?  @unique
  passwordHash String?
  email        String   @unique
  name         String?
  avatarUrl String?
  plan      UserPlan @default(FREE)
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces   Workspace[]
  creditLedger CreditLedger[]
  contentItems ContentItem[]
  contentJobs  ContentJob[]
  subscription Subscription?
  aiUsageLogs  AiUsageLog[]

  @@index([clerkId])
  @@index([email])
  @@map("users")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 UserPlan           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  creditAllowance      Int                @default(100)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model Workspace {
  id               String          @id @default(cuid())
  userId           String
  name             String
  websiteUrl       String?
  status           WorkspaceStatus @default(PENDING)
  brandSummary     Json?
  audienceInsights Json?
  rescrapeCount    Int             @default(0)
  archivedSummaries Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItems ContentItem[]
  contentJobs  ContentJob[]
  strategyRuns StrategyRun[]
  competitors  Competitor[]
  competitorKeywords CompetitorKeyword[]
  keywordOpportunities KeywordOpportunity[]
  serpAnalyses SerpAnalysis[]
  socialConnections SocialConnection[]

  @@index([userId])
  @@map("workspaces")
}

model Competitor {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  domain          String?
  description     String?
  category        String?
  audienceGuess   String?
  source          String    @default("AI") // 'AI', 'MANUAL'
  type            String?   // 'DIRECT', 'INDIRECT', 'ASPIRATIONAL'
  userDecision    String?   // 'ACCEPTED', 'REJECTED'
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("competitors")
}

// SEO Intelligence: real keyword data pulled from DataForSEO (domain_keywords API)
// Scanned at most once per 7 days per domain to control API costs.
model CompetitorKeyword {
  id               String   @id @default(cuid())
  workspaceId      String
  competitorDomain String
  keyword          String
  searchVolume     Int      @default(0)
  difficulty       Int      @default(0)  // 0-100
  competition      Float    @default(0)  // 0.0-1.0
  rankingPosition  Int?     // organic rank of competitor
  rankingUrl       String?
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, competitorDomain])
  @@map("competitor_keywords")
}

// SEO Intelligence: gap keywords not yet owned by the client.
// Opportunity score = (searchVolume * 0.6) + ((1 - competition) * 0.4)
model KeywordOpportunity {
  id               String   @id @default(cuid())
  workspaceId      String
  keyword          String
  searchVolume     Int      @default(0)
  competition      Float    @default(0)
  opportunityScore Float    @default(0)
  sourceCompetitor String?  // domain that ranked for this keyword
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, opportunityScore])
  @@map("keyword_opportunities")
}

// SEO Intelligence: AI-analyzed SERP report per keyword.
// Refreshed at most once per 24 hours per keyword.
model SerpAnalysis {
  id          String   @id @default(cuid())
  workspaceId String
  keyword     String
  rawResults  Json     // top 10 SERP results from DataForSEO
  analysis    String   @db.Text  // Gemini AI insight report
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, keyword])
  @@map("serp_analyses")
}

model StrategyRun {
  id               String    @id @default(cuid())
  workspaceId      String
  status           JobStatus @default(PENDING)
  brandSummary     Json?
  audienceInsights Json?
  contentPillars   Json?
  strategyDoc      Json?
  generatedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("strategy_runs")
}

model ContentItem {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String?
  type        ContentType
  channel     ContentChannel
  tone        ContentTone?
  topic       String
  content          String         @db.Text
  status           ContentStatus  @default(DRAFT)
  creditsCost      Int            @default(0)
  jobId            String?
  scheduledAtUtc   DateTime?
  scheduledTimezone String?
  publishedAtUtc   DateTime?
  failedReason     String?
  campaign         String?
  notes            String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@map("content_items")
}

model ContentJob {
  id            String    @id @default(cuid())
  userId        String
  workspaceId   String?
  type          JobType
  status        JobStatus @default(PENDING)
  inputPayload  Json
  outputPayload Json?
  errorMessage  String?
  creditsCost   Int       @default(0)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("content_jobs")
}

/// Append-only. Never update rows. Balance = SUM(amount) WHERE userId = ?
model CreditLedger {
  id           String     @id @default(cuid())
  userId       String
  type         LedgerType
  feature      String
  amount       Int        // positive = in, negative = out
  balanceAfter Int
  jobId        String?
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("credit_ledger")
}

// ─── Social Publishing ────────────────────────────────────────────────────────

/// Stores OAuth-connected social media accounts per workspace.
/// Tokens are NEVER stored in plaintext — only refs to encrypted vault entries.
model SocialConnection {
  id                       String                 @id @default(cuid())
  workspaceId              String
  platform                 SocialPlatform
  accountName              String
  accountIdentifier        String                 // handle, page-id, or URN
  authProvider             String                 @default("oauth2")
  encryptedAccessTokenRef  String?                // reference to vault / env-encrypted token
  encryptedRefreshTokenRef String?                // reference to vault / env-encrypted refresh token
  scopesJson               Json?                  // granted OAuth scopes as JSON array
  status                   SocialConnectionStatus @default(CONNECTED)
  isDefault                Boolean                @default(false)
  tokenExpiresAt           DateTime?              // when the access token expires (for proactive refresh)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  lastSyncAt               DateTime?

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishJobs SocialPublishJob[]

  @@index([workspaceId])
  @@index([workspaceId, platform])
  @@map("social_connections")
}

/// A single publish job: one content item → one social destination.
/// Must be processed by a background worker, NOT inside an HTTP request.
model SocialPublishJob {
  id                 String              @id @default(cuid())
  workspaceId        String
  contentItemId      String?             // links to ContentItem if generated by Contivo
  socialConnectionId String
  platform           SocialPlatform
  scheduledAtUtc     DateTime?           // null = publish immediately
  timezone           String?             @default("UTC")
  status             SocialPublishStatus @default(DRAFT)
  externalPostId     String?             // returned by platform API after publish
  externalPostUrl    String?             // deep-link to the published post
  lastError          String?             @db.Text
  retryCount         Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  publishedAtUtc     DateTime?

  connection SocialConnection  @relation(fields: [socialConnectionId], references: [id], onDelete: Cascade)
  logs       SocialPublishLog[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([socialConnectionId])
  @@index([scheduledAtUtc, status]) // for scheduler worker queries
  @@map("social_publish_jobs")
}

/// Append-only audit trail for every action taken on a publish job.
/// Never update rows — only insert.
model SocialPublishLog {
  id              String   @id @default(cuid())
  publishJobId    String
  action          String   // e.g. VALIDATE, PUBLISH_ATTEMPT, RETRY, CANCELLED
  status          String   // SUCCESS | FAILURE | SKIPPED
  requestSummary  String?  @db.Text // sanitised request body (no tokens)
  responseSummary String?  @db.Text // sanitised response body
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  job SocialPublishJob @relation(fields: [publishJobId], references: [id], onDelete: Cascade)

  @@index([publishJobId])
  @@map("social_publish_logs")
}

/// Immutable AI cost audit trail.
model AiUsageLog {
  id               String   @id @default(cuid())
  userId           String
  model            String
  feature          String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Decimal  @db.Decimal(10, 6)
  jobId            String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}
