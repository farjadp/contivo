generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  clerkId      String?        @unique
  passwordHash String?
  email        String         @unique
  name         String?
  avatarUrl    String?
  plan         UserPlan       @default(FREE)
  role         UserRole       @default(USER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  aiUsageLogs  AiUsageLog[]
  contentItems ContentItem[]
  contentJobs  ContentJob[]
  creditLedger CreditLedger[]
  subscription Subscription?
  workspaces   Workspace[]

  @@index([clerkId])
  @@index([email])
  @@map("users")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 UserPlan           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  creditAllowance      Int                @default(100)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model Workspace {
  id                   String               @id @default(cuid())
  userId               String
  name                 String
  websiteUrl           String?
  status               WorkspaceStatus      @default(PENDING)
  brandSummary         Json?
  audienceInsights     Json?
  rescrapeCount        Int                  @default(0)
  archivedSummaries    Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  competitorKeywords   CompetitorKeyword[]
  competitors          Competitor[]
  contentItems         ContentItem[]
  contentJobs          ContentJob[]
  keywordOpportunities KeywordOpportunity[]
  serpAnalyses         SerpAnalysis[]
  socialConnections    SocialConnection[]
  strategyRuns         StrategyRun[]
  strategicReports     StrategicReport[]
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("workspaces")
}

model StrategicReport {
  id                String    @id @default(cuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId            String

  // File paths
  docxPath          String
  pdfPath           String

  // Metadata
  reportDate        DateTime @default(now())
  fileSize          Int
  sectionsIncluded  Json

  // Analytics snapshot (frozen at generation time)
  competitorsCount  Int
  keywordsAnalyzed  Int
  chartsGenerated   Int

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([workspaceId])
  @@index([userId])
  @@index([reportDate])
  @@map("strategic_reports")
}

model Competitor {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  domain        String?
  description   String?
  category      String?
  audienceGuess String?
  source        String    @default("AI")
  type          String?
  userDecision  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("competitors")
}

model CompetitorKeyword {
  id               String    @id @default(cuid())
  workspaceId      String
  competitorDomain String
  keyword          String
  searchVolume     Int       @default(0)
  difficulty       Int       @default(0)
  competition      Float     @default(0)
  rankingPosition  Int?
  rankingUrl       String?
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, competitorDomain])
  @@map("competitor_keywords")
}

model KeywordOpportunity {
  id               String    @id @default(cuid())
  workspaceId      String
  keyword          String
  searchVolume     Int       @default(0)
  competition      Float     @default(0)
  opportunityScore Float     @default(0)
  sourceCompetitor String?
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, opportunityScore])
  @@map("keyword_opportunities")
}

model SerpAnalysis {
  id          String    @id @default(cuid())
  workspaceId String
  keyword     String
  rawResults  Json
  analysis    String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, keyword])
  @@map("serp_analyses")
}

model StrategyRun {
  id               String    @id @default(cuid())
  workspaceId      String
  status           JobStatus @default(PENDING)
  brandSummary     Json?
  audienceInsights Json?
  contentPillars   Json?
  strategyDoc      Json?
  generatedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("strategy_runs")
}

model ContentItem {
  id                String         @id @default(cuid())
  userId            String
  workspaceId       String?
  type              ContentType
  channel           ContentChannel
  tone              ContentTone?
  topic             String
  content           String
  status            ContentStatus  @default(DRAFT)
  creditsCost       Int            @default(0)
  jobId             String?
  scheduledAtUtc    DateTime?
  scheduledTimezone String?
  publishedAtUtc    DateTime?
  failedReason      String?
  campaign          String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?     @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([workspaceId])
  @@map("content_items")
}

model ContentJob {
  id            String     @id @default(cuid())
  userId        String
  workspaceId   String?
  type          JobType
  status        JobStatus  @default(PENDING)
  inputPayload  Json
  outputPayload Json?
  errorMessage  String?
  creditsCost   Int        @default(0)
  createdAt     DateTime   @default(now())
  completedAt   DateTime?
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("content_jobs")
}

/// Append-only. Never update rows. Balance = SUM(amount) WHERE userId = ?
model CreditLedger {
  id           String     @id @default(cuid())
  userId       String
  type         LedgerType
  feature      String
  amount       Int
  balanceAfter Int
  jobId        String?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("credit_ledger")
}

/// Stores OAuth-connected social media accounts per workspace.
/// Tokens are NEVER stored in plaintext — only refs to encrypted vault entries.
model SocialConnection {
  id                       String                 @id @default(cuid())
  workspaceId              String
  platform                 SocialPlatform
  accountName              String
  accountIdentifier        String
  authProvider             String                 @default("oauth2")
  encryptedAccessTokenRef  String?
  encryptedRefreshTokenRef String?
  scopesJson               Json?
  status                   SocialConnectionStatus @default(CONNECTED)
  isDefault                Boolean                @default(false)
  tokenExpiresAt           DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  lastSyncAt               DateTime?
  workspace                Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishJobs              SocialPublishJob[]

  @@index([workspaceId])
  @@index([workspaceId, platform])
  @@map("social_connections")
}

/// A single publish job: one content item → one social destination.
/// Must be processed by a background worker, NOT inside an HTTP request.
model SocialPublishJob {
  id                 String              @id @default(cuid())
  workspaceId        String
  contentItemId      String?
  socialConnectionId String
  platform           SocialPlatform
  scheduledAtUtc     DateTime?
  timezone           String?             @default("UTC")
  status             SocialPublishStatus @default(DRAFT)
  externalPostId     String?
  externalPostUrl    String?
  lastError          String?
  retryCount         Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  publishedAtUtc     DateTime?
  connection         SocialConnection    @relation(fields: [socialConnectionId], references: [id], onDelete: Cascade)
  logs               SocialPublishLog[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([socialConnectionId])
  @@index([scheduledAtUtc, status])
  @@map("social_publish_jobs")
}

/// Append-only audit trail for every action taken on a publish job.
/// Never update rows — only insert.
model SocialPublishLog {
  id              String           @id @default(cuid())
  publishJobId    String
  action          String
  status          String
  requestSummary  String?
  responseSummary String?
  errorMessage    String?
  createdAt       DateTime         @default(now())
  job             SocialPublishJob @relation(fields: [publishJobId], references: [id], onDelete: Cascade)

  @@index([publishJobId])
  @@map("social_publish_logs")
}

/// Immutable AI cost audit trail.
model AiUsageLog {
  id               String   @id @default(cuid())
  userId           String
  model            String
  feature          String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Decimal  @db.Decimal(10, 6)
  jobId            String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

model activity_logs {
  id           String   @id
  user_id      String
  workspace_id String?
  action       String
  detail       Json?
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id, created_at(sort: Desc)], map: "idx_activity_logs_user_created")
  @@index([workspace_id, created_at(sort: Desc)], map: "idx_activity_logs_workspace_created")
}

model admin_user_controls {
  user_id          String    @id
  access_status    String    @default("ACTIVE")
  suspended_at     DateTime? @db.Timestamptz(6)
  suspended_reason String?
  reactivated_at   DateTime? @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([access_status, updated_at(sort: Desc)], map: "idx_admin_user_controls_status")
}

model admin_workspace_controls {
  workspace_id    String    @id
  is_archived     Boolean   @default(false)
  archived_at     DateTime? @db.Timestamptz(6)
  archived_reason String?
  restored_at     DateTime? @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)

  @@index([is_archived, updated_at(sort: Desc)], map: "idx_admin_workspace_controls_archived")
}

model app_settings {
  key        String   @id
  value      String
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model competitor_discovery_runs {
  id                   String   @id
  user_id              String
  workspace_id         String
  run_number           Int
  source               String
  discovered_count     Int      @default(0)
  competitors_snapshot Json
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  @@unique([workspace_id, run_number])
  @@index([user_id, created_at(sort: Desc)], map: "idx_comp_discovery_user_created")
  @@index([workspace_id, created_at(sort: Desc)], map: "idx_comp_discovery_workspace_created")
}

model content_framework_metadata {
  id                    String   @id
  user_id               String
  workspace_id          String
  content_item_id       String?
  event_name            String
  framework_id          String
  framework_name        String
  framework_category    String
  selection_mode        String   @default("auto")
  selection_reason      String?
  goal                  String?
  platform              String?
  funnel_stage          String?
  quality_scores        Json?
  fallback_used         Boolean  @default(false)
  fallback_framework_id String?
  metadata              Json?
  created_at            DateTime @default(now()) @db.Timestamptz(6)

  @@index([content_item_id, created_at(sort: Desc)], map: "idx_framework_metadata_content_item_created")
  @@index([created_at(sort: Desc)], map: "idx_framework_metadata_created")
  @@index([framework_id, created_at(sort: Desc)], map: "idx_framework_metadata_framework_created")
  @@index([workspace_id, created_at(sort: Desc)], map: "idx_framework_metadata_workspace_created")
}

enum UserPlan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum UserRole {
  USER
  ADMIN
}

enum WorkspaceStatus {
  PENDING
  CRAWLING
  ANALYZING
  READY
  ERROR
}

enum ContentChannel {
  linkedin
  twitter
  instagram
  email
  blog
}

enum ContentTone {
  professional
  friendly
  bold
  educational
  persuasive
}

enum ContentType {
  POST
  THREAD
  ARTICLE
  EMAIL
  CAPTION
  OUTLINE
}

enum ContentStatus {
  DRAFT
  GENERATED
  EDITED
  READY
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobType {
  INSTANT_CONTENT
  WEBSITE_CRAWL
  BRAND_ANALYSIS
  STRATEGY_GENERATION
  ARTICLE_DRAFT
}

enum LedgerType {
  ALLOCATION
  CONSUMPTION
  TOP_UP
  REFUND
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum SocialPlatform {
  LINKEDIN
  X
  FACEBOOK
  INSTAGRAM
  TIKTOK
}

enum SocialConnectionStatus {
  CONNECTED
  EXPIRED
  FAILED
  REVOKED
  PENDING_REAUTH
}

enum SocialPublishStatus {
  DRAFT
  READY
  SCHEDULED
  PUBLISH_QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}
